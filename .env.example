# ─────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in the values.
# Never commit .env.local — it is gitignored.
# ─────────────────────────────────────────────────────────────

# Supabase
# For local dev, use the values printed by `supabase start`.
# For production, use your Supabase project's API settings.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # SERVER ONLY — never prefix with NEXT_PUBLIC_

# Cloudinary (API key and secret are server-only)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Optional: dedicated unsigned-disabled upload preset name (signed uploads only)
CLOUDINARY_UPLOAD_FOLDER=sarees

# Business config
NEXT_PUBLIC_WHATSAPP_NUMBER=91XXXXXXXXXX
NEXT_PUBLIC_BUSINESS_NAME=Your Saree House
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Email (Resend)
RESEND_API_KEY=
INQUIRY_NOTIFICATION_EMAIL=
RESEND_FROM_EMAIL=onboarding@resend.dev

# Analytics (public — safe in browser)
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_CLARITY_PROJECT_ID=
NEXT_PUBLIC_PINTEREST_TAG_ID=
